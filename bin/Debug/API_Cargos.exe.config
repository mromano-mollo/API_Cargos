<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <connectionStrings>
        <!-- Set real credentials or use env var ConnectionStrings__CargosDb -->
        <add name="CargosDb"
             connectionString="Data Source=intranetdb;Initial Catalog=sitointerno;Persist Security Info=True;User ID=sa;Password=m0b1l3;TrustServerCertificate=True"
             providerName="System.Data.SqlClient" />
    </connectionStrings>

    <appSettings>
        <add key="Db.ContractsViewName" value="Cargos_Vista_Contratti" />
        <add key="Db.ContractsSyncProcedure" value="Cargos_Sync_Contratti_Frontiera" />
        <add key="Db.CommandTimeoutSeconds" value="120" />
        <add key="Worker.BatchSize" value="100" />
        <!-- Keep true until API send pipeline is completed -->
        <add key="Worker.DryRun" value="true" />
        <add key="Cargos.BaseUrl" value="https://cargos.poliziadistato.it/CARGOS_API" />
        <add key="Cargos.TokenPath" value="/api/Token" />
        <add key="Cargos.SendPath" value="/api/Send" />
        <add key="Cargos.Username" value="" />
        <add key="Cargos.Password" value="" />
        <add key="Cargos.ApiKey" value="" />
        <add key="Cargos.Organization" value="" />
        <add key="Cargos.HttpTimeoutSeconds" value="60" />
    </appSettings>

    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
</configuration>
